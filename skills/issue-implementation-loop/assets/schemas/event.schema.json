{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Issue Implementation Loop Event",
  "type": "object",
  "required": ["event_id", "type", "epic_id"],
  "properties": {
    "event_id": {"type": "string"},
    "epic_id": {"type": "string"},
    "envelope_revision": {"type": "integer"},
    "type": {
      "enum": [
        "issue_status_changed",
        "review_status_changed",
        "pr_created",
        "pr_merged",
        "signal_recorded",
        "human_request_opened",
        "human_request_resolved"
      ]
    },
    "issue": {"type": "string"},
    "status": {"type": "string"},
    "branch": {"type": "string"},
    "worktree": {"type": "string"},
    "base_sha": {"type": "string"},
    "head_sha": {"type": "string"},
    "range": {"type": "string"},
    "review_range": {"type": "string"},
    "pr": {"type": "string"},
    "merge_commit": {"type": "string"},
    "signal": {"type": "string"},
    "id": {"type": "string"},
    "scope": {"enum": ["issue", "descendants", "resource", "epic"]},
    "resource": {"type": "string"},
    "reason": {"type": "string"}
  }
}
