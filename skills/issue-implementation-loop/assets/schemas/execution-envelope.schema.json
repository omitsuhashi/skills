{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Issue Implementation Loop Execution Envelope",
  "type": "object",
  "required": ["schema_version", "epic_id", "revision", "epic_base", "execution_policy", "review_policy", "human_policy", "context_policy", "remote_write_policy", "work_items"],
  "properties": {
    "schema_version": {"const": 1},
    "epic_id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "revision": {"type": "integer", "minimum": 1},
    "epic_base": {
      "type": "object",
      "required": ["ref", "sha"],
      "properties": {
        "ref": {"type": "string", "minLength": 1},
        "sha": {"type": "string", "pattern": "^(?:[0-9a-fA-F]{40}|[0-9a-fA-F]{64})$"},
        "branch_state": {"enum": ["reserved", "create_on_run", "active", "missing"]},
        "worktree_path": {"type": "string"}
      }
    },
    "execution_policy": {
      "type": "object",
      "required": ["worker_context_required", "coordinator_may_implement", "serial_fallback_mode"],
      "properties": {
        "parallel_preferred": {"type": "boolean"},
        "serial_fallback_preapproved": {"type": "boolean"},
        "worker_context_required": {"const": true},
        "coordinator_may_implement": {"const": false},
        "serial_fallback_mode": {"const": "worker_context_only"},
        "implementation_slots": {"type": "integer", "minimum": 1},
        "review_slots": {"type": "integer", "minimum": 1},
        "wave_is_barrier": {"type": "boolean"}
      }
    },
    "review_policy": {
      "type": "object",
      "required": ["max_review_cycles"],
      "properties": {
        "max_review_cycles": {"type": "integer", "minimum": 1, "maximum": 2},
        "max_fix_cycles": {"type": "integer", "minimum": 0, "maximum": 2}
      }
    },
    "human_policy": {"type": "object"},
    "context_policy": {
      "type": "object",
      "required": ["paths_first", "max_worker_packet_words", "max_worker_report_words", "include_full_spec_text", "include_full_ledger_text"],
      "properties": {
        "paths_first": {"const": true},
        "max_worker_packet_words": {"type": "integer", "minimum": 1},
        "max_worker_report_words": {"type": "integer", "minimum": 1},
        "include_full_spec_text": {"const": false},
        "include_full_ledger_text": {"const": false}
      }
    },
    "remote_write_policy": {
      "type": "object",
      "required": ["mode", "approved_actions"],
      "properties": {
        "mode": {"enum": ["local_only", "per_action", "batch_draft_prs", "batch_issue_prs"]},
        "approved_actions": {"type": "array"},
        "issue_prs": {
          "type": "object",
          "required": ["base", "merge"],
          "properties": {
            "base": {"const": "epic_base.ref"},
            "merge": {"const": "agent_default_with_human_escalation"}
          }
        },
        "final_pr": {
          "type": "object",
          "required": ["head", "base", "merge"],
          "properties": {
            "head": {"const": "epic_base.ref"},
            "base": {"const": "main"},
            "merge": {"const": "human_only"}
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"mode": {"const": "batch_issue_prs"}},
            "required": ["mode"]
          },
          "then": {
            "required": ["issue_prs", "final_pr"]
          }
        }
      ]
    },
    "work_items": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["branch", "worktree_path", "worktree_state", "base_policy", "write_scope", "dependencies"],
        "properties": {
          "branch": {"type": "string"},
          "worktree_path": {"type": "string"},
          "worktree_state": {"enum": ["reserved", "create_on_run", "active", "missing"]},
          "base_policy": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {"enum": ["epic_base", "blocker_head", "integration_head"]},
              "issue": {"type": "string"},
              "integration_issue": {"type": "string"}
            }
          },
          "write_scope": {"type": "array", "items": {"type": "string"}},
          "dependencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["issue", "strength", "release_on", "base_effect"],
              "properties": {
                "issue": {"type": "string"},
                "strength": {"enum": ["hard", "soft"]},
                "release_on": {"enum": ["artifact_ready", "review_approved", "integrated", "pr_opened", "pr_merged", "human_decision", "external_condition"]},
                "base_effect": {"enum": ["none", "branch_from_blocker_head", "branch_from_integration_head"]}
              }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "remote_write_policy": {
            "properties": {"mode": {"const": "batch_issue_prs"}},
            "required": ["mode"]
          }
        },
        "required": ["remote_write_policy"]
      },
      "then": {
        "properties": {
          "epic_base": {
            "required": ["ref", "sha", "branch_state"]
          }
        }
      }
    }
  ]
}
