{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Issue Implementation Loop Input Packet",
  "type": "object",
  "required": ["schema_version", "repo_root", "epic_id", "spec", "work_items", "delivery_intent"],
  "properties": {
    "schema_version": {"const": 1},
    "repo_root": {"type": "string"},
    "epic_id": {"type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"},
    "artifact_root": {"type": "string"},
    "spec": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": {"type": "string"},
        "approved_revision": {"type": "integer"},
        "approved_hash": {"type": "string"}
      }
    },
    "work_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "acceptance_criteria", "verification", "write_scope"],
        "properties": {
          "id": {"type": "string", "pattern": "^[A-Z0-9]+-[0-9]+$"},
          "title": {"type": "string"},
          "source": {"type": "object"},
          "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
          "non_goals": {"type": "array", "items": {"type": "string"}},
          "verification": {"type": "array", "items": {"type": "string"}},
          "write_scope": {"type": "array", "items": {"type": "string"}},
          "dependencies": {"type": "array"}
        }
      }
    },
    "delivery_intent": {"enum": ["local_only", "per_action", "batch_draft_prs", "batch_issue_prs"]}
  }
}
